interface VUMeterProps {
  peakL: number; peakR: number;
  peakHoldL: number; peakHoldR: number;
  height?: number; segments?: number; showLabels?: boolean;
}

export default function VUMeter({
  peakL, peakR, peakHoldL, peakHoldR, height = 40, segments = 14, showLabels = true
}: VUMeterProps) {
  
  const renderBars = (peak: number, hold: number) => {
    const bars = [];
    for (let i = 0; i < segments; i++) {
      const threshold = (i + 1) / segments;
      const isActive = peak >= threshold;
      const isHold = Math.abs(hold - threshold) < (1 / segments);
      
      // Menentukan warna LED berdasarkan tinggi desibel suara (Hijau -> Kuning -> Merah)
      let color = "#10b981"; // Hijau (Aman)
      if (threshold > 0.85) color = "#ef4444"; // Merah (Clip/Bahaya)
      else if (threshold > 0.65) color = "#f59e0b"; // Kuning (Warning)

      bars.push(
        <div key={i} style={{
          flex: 1,
          height: "100%",
          background: isActive ? color : isHold ? `${color}aa` : "#1f2937",
          borderRight: "1px solid #0b0f19",
          transition: "background 0.05s ease"
        }} />
      );
    }
    return bars;
  };

  return (
    <div style={{ width: "100%", background: "#0b0f19", padding: "6px", borderRadius: "4px", boxSizing: "border-box" }}>
      {showLabels && <div style={{ display: "flex", justifyContent: "space-between", fontSize: "8px", color: "#6b7280", marginBottom: "3px" }}><span>L</span><span>MASTER LEVEL METER</span><span>R</span></div>}
      <div style={{ display: "flex", flexDirection: "column", gap: "4px", height: `${height}px` }}>
        <div style={{ flex: 1, display: "flex", background: "#111827", borderRadius: "2px", overflow: "hidden" }}>
          {renderBars(peakL, peakHoldL)}
        </div>
        <div style={{ flex: 1, display: "flex", background: "#111827", borderRadius: "2px", overflow: "hidden" }}>
          {renderBars(peakR, peakHoldR)}
        </div>
      </div>
    </div>
  );
}
